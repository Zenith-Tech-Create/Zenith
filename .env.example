# Zenith Configuration

# Lemonsqueezy API Key (for license validation)
# Get this from your Lemonsqueezy dashboard: https://app.lemonsqueezy.com/settings/api
# This allows Zenith to validate customer license keys online
LEMONSQUEEZY_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Custom Lemonsqueezy API endpoint (leave blank to use default)
# LEMONSQUEEZY_API_ENDPOINT=https://api.lemonsqueezy.com/v1/licenses/validate
